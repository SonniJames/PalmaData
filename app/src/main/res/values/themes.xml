<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.PalmaData" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/palma_green_dark</item>
        <item name="colorPrimaryVariant">@color/palma_green_medium</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/palma_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/status_bar_color</item>
        <item name="android:windowBackground">@color/grid_background</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:ignore="NewApi">true</item>
    </style>

    <style name="WorkerDialogTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="colorPrimary">@color/palma_green_dark</item>
        <item name="colorAccent">@color/palma_gold</item>
    </style>

    <!-- Tecla numérica -->
    <style name="KeyboardButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/divider</item>
        <item name="backgroundTint">@color/white</item>
    </style>

    <!-- Botón de acción (LINEA-PALMA, PALMA, ENFERMEDADES) -->
    <style name="KeyboardActionButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/palma_green_dark</item>
        <item name="android:textColor">@color/white</item>
    </style>

</resources>