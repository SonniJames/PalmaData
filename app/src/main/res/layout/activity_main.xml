<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/grid_background">

    <!-- ===== HEADER: Logo + PalmaData ===== -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@color/header_background"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/logo_palma"
            android:scaleType="fitCenter"
            android:contentDescription="Logo PalmaData" />

        <View android:layout_width="12dp" android:layout_height="match_parent" />

        <ImageView
            android:id="@+id/imgTextoPalmaData"
            android:layout_width="0dp"
            android:layout_height="26dp"
            android:layout_weight="1"
            android:adjustViewBounds="true"
            android:contentDescription="PalmaData"
            android:scaleType="fitStart"
            android:src="@drawable/texto_palma_data" />

        <!-- Indicador GPS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/imgGpsIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:contentDescription="GPS"
                android:tint="@color/palma_gold" />

            <TextView
                android:id="@+id/tvGpsStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS"
                android:textColor="@color/palma_gold"
                android:textSize="8sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ===== BARRA TRABAJADOR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/worker_bar_background"
        android:orientation="vertical"
        android:elevation="3dp">

        <TextView
            android:id="@+id/tvWorkerSelector"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center"
            android:text="@string/worker_not_selected"
            android:textColor="@color/worker_not_set"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Coordenadas GPS -->
        <TextView
            android:id="@+id/tvGpsCoords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ===== GRID DE MÓDULOS ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvModules"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <!-- ===== BOTÓN SINCRONIZAR ===== -->
    <Button
        android:id="@+id/btnSincronizar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="12dp"
        android:text="SINCRONIZAR"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/palma_green_dark" />

</LinearLayout>