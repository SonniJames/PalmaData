<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/grid_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal" android:background="@color/header_background" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="6dp">
        <ImageView android:layout_width="52dp" android:layout_height="52dp" android:src="@drawable/logo_palma" android:scaleType="fitCenter" android:contentDescription="Logo" />
        <View android:layout_width="12dp" android:layout_height="match_parent" />
        <ImageView android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:src="@drawable/texto_palma_data" android:scaleType="fitStart" android:adjustViewBounds="true" android:contentDescription="PalmaData" />
    </LinearLayout>
    <TextView android:layout_width="match_parent" android:layout_height="48dp" android:text="CORTADOR / RECOLECTOR"
        android:gravity="center" android:textSize="16sp" android:textColor="@color/text_secondary"
        android:background="@color/white" android:elevation="2dp" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <!-- Cortador -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Cortador" android:textSize="13sp" android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />
            <AutoCompleteTextView android:id="@+id/acCortador"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Buscar cortador..." android:textSize="15sp"
                android:textColor="@color/text_primary" android:textColorHint="@color/divider"
                android:background="@color/white" android:paddingStart="12dp" android:paddingEnd="12dp"
                android:inputType="textPersonName" android:completionThreshold="1"
                android:layout_marginBottom="24dp" />

            <!-- Recolector -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Recolector" android:textSize="13sp" android:textColor="@color/text_secondary"
                android:layout_marginBottom="4dp" />
            <AutoCompleteTextView android:id="@+id/acRecolector"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:hint="Buscar recolector..." android:textSize="15sp"
                android:textColor="@color/text_primary" android:textColorHint="@color/divider"
                android:background="@color/white" android:paddingStart="12dp" android:paddingEnd="12dp"
                android:inputType="textPersonName" android:completionThreshold="1"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <Button android:id="@+id/btnAccion" android:layout_width="match_parent" android:layout_height="60dp"
        android:layout_margin="16dp" android:text="LINEA-PALMA" android:textSize="15sp"
        android:textStyle="bold" android:backgroundTint="@color/palma_green_dark" android:textColor="@color/white" />
</LinearLayout>