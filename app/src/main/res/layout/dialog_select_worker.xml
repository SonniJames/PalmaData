<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/header_background"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/logo_palma"
            android:scaleType="fitCenter"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Seleccionar Trabajador"
            android:textColor="@color/dialog_title_text"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Buscador -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_search"
            android:tint="@color/text_secondary"
            android:contentDescription="Buscar" />

        <EditText
            android:id="@+id/etSearchWorker"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="Buscar trabajador..."
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@null"
            android:inputType="textPersonName"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

    </LinearLayout>

    <!-- Línea divisora -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Lista de trabajadores -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWorkers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="350dp" />

    <!-- Mensaje cuando no hay resultados -->
    <TextView
        android:id="@+id/tvNoWorkers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:text="No se encontraron trabajadores"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Botón cancelar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="end"
        android:paddingEnd="12dp"
        android:paddingStart="12dp">

        <Button
            android:id="@+id/btnCancelWorker"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:textColor="@color/palma_green_dark" />

    </LinearLayout>

</LinearLayout>