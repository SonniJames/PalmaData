                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="3" android:text="R. cosechados" android:textSize="13sp" android:textColor="@color/text_primary" />
                <TextView android:id="@+id/tvValor1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="0" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/palma_green_dark" android:gravity="center" />
                <Button android:id="@+id/btnMenos1" android:layout_width="40dp" android:layout_height="40dp" android:text="-" android:textSize="18sp" android:backgroundTint="@color/white" android:textColor="@color/text_primary" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnMas1" android:layout_width="40dp" android:layout_height="40dp" android:text="+" android:textSize="18sp" android:backgroundTint="@color/palma_green_dark" android:textColor="@color/white" />
            </LinearLayout>
            <!-- 2. R. verdes -->
