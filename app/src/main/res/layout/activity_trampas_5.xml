<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/grid_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal" android:background="@color/header_background" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="6dp">
        <ImageView android:layout_width="52dp" android:layout_height="52dp" android:src="@drawable/logo_palma" android:scaleType="fitCenter" android:contentDescription="Logo" />
        <View android:layout_width="12dp" android:layout_height="match_parent" />
        <ImageView android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:src="@drawable/texto_palma_data" android:scaleType="fitStart" android:adjustViewBounds="true" android:contentDescription="PalmaData" />
    </LinearLayout>
    <TextView android:layout_width="match_parent" android:layout_height="48dp" android:text="VARIOS"
        android:gravity="center" android:textSize="16sp" android:textColor="@color/text_secondary"
        android:background="@color/white" android:elevation="2dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:orientation="vertical" android:padding="24dp">

        <!-- Con/sin feromona -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@color/white" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Con/sin feromona" android:textSize="15sp" android:textColor="@color/text_primary" />
            <CheckBox android:id="@+id/cbFeromona" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:buttonTint="@color/palma_green_dark" />
        </LinearLayout>

        <!-- Cambio feromona -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@color/white" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Cambio feromona" android:textSize="15sp" android:textColor="@color/text_primary" />
            <CheckBox android:id="@+id/cbCambioFeromona" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:buttonTint="@color/palma_green_dark" />
        </LinearLayout>

        <!-- Cambio atrayente -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@color/white" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Cambio atrayente" android:textSize="15sp" android:textColor="@color/text_primary" />
            <CheckBox android:id="@+id/cbCambioAtrayente" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:buttonTint="@color/palma_green_dark" />
        </LinearLayout>

    </LinearLayout>

    <Button android:id="@+id/btnAccion" android:layout_width="match_parent" android:layout_height="60dp"
        android:layout_margin="16dp" android:text="OBSERVACIONES" android:textSize="15sp"
        android:textStyle="bold" android:backgroundTint="@color/palma_green_dark" android:textColor="@color/white" />
</LinearLayout>