<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/grid_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal" android:background="@color/header_background" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="6dp">
        <ImageView android:layout_width="52dp" android:layout_height="52dp" android:src="@drawable/logo_palma" android:scaleType="fitCenter" android:contentDescription="Logo" />
        <View android:layout_width="12dp" android:layout_height="match_parent" />
        <ImageView android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:src="@drawable/texto_palma_data" android:scaleType="fitStart" android:adjustViewBounds="true" android:contentDescription="PalmaData" />
    </LinearLayout>
    <TextView android:layout_width="match_parent" android:layout_height="48dp" android:text="DEFOLIACIONES"
        android:gravity="center" android:textSize="16sp" android:textColor="@color/text_secondary"
        android:background="@color/white" android:elevation="2dp" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- 05 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@color/white" android:paddingStart="16dp" android:paddingEnd="16dp"
                android:layout_marginBottom="2dp">
                <TextView android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="05" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/palma_green_dark" />
                <EditText android:id="@+id/etDefol5" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:hint="0.0" android:textSize="16sp"
                    android:inputType="numberDecimal" android:background="@color/grid_background"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- 13 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@color/white" android:paddingStart="16dp" android:paddingEnd="16dp"
                android:layout_marginBottom="2dp">
                <TextView android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="13" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/palma_green_dark" />
                <EditText android:id="@+id/etDefol13" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:hint="0.0" android:textSize="16sp"
                    android:inputType="numberDecimal" android:background="@color/grid_background"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- 21 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@color/white" android:paddingStart="16dp" android:paddingEnd="16dp"
                android:layout_marginBottom="2dp">
                <TextView android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="21" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/palma_green_dark" />
                <EditText android:id="@+id/etDefol21" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:hint="0.0" android:textSize="16sp"
                    android:inputType="numberDecimal" android:background="@color/grid_background"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- 29 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@color/white" android:paddingStart="16dp" android:paddingEnd="16dp"
                android:layout_marginBottom="2dp">
                <TextView android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="29" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/palma_green_dark" />
                <EditText android:id="@+id/etDefol29" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:hint="0.0" android:textSize="16sp"
                    android:inputType="numberDecimal" android:background="@color/grid_background"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- 37 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@color/white" android:paddingStart="16dp" android:paddingEnd="16dp"
                android:layout_marginBottom="2dp">
                <TextView android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="37" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/palma_green_dark" />
                <EditText android:id="@+id/etDefol37" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:hint="0.0" android:textSize="16sp"
                    android:inputType="numberDecimal" android:background="@color/grid_background"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button android:id="@+id/btnAccion" android:layout_width="match_parent" android:layout_height="60dp"
        android:layout_margin="16dp" android:text="OBSERVACIONES" android:textSize="15sp"
        android:textStyle="bold" android:backgroundTint="@color/palma_green_dark" android:textColor="@color/white" />
</LinearLayout>