<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Título -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/header_background"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/logo_palma"
            android:scaleType="fitCenter"
            android:contentDescription="Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Seleccionar Plantación"
            android:textColor="@color/dialog_title_text"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Lista de plantaciones -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlantaciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- Mensaje cuando no hay plantaciones -->
    <TextView
        android:id="@+id/tvNoPlantaciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:text="No hay plantaciones registradas.\n(Se conectará al DataLake próximamente)"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Botón cancelar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="end"
        android:paddingEnd="12dp"
        android:paddingStart="12dp">

        <Button
            android:id="@+id/btnCancelPlantacion"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:textColor="@color/palma_green_dark" />

    </LinearLayout>

</LinearLayout>