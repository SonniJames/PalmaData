<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@color/white">
    <EditText android:id="@+id/etBuscar" android:layout_width="match_parent" android:layout_height="52dp"
        android:hint="🔍 Buscar..." android:textSize="14sp" android:paddingStart="16dp" android:paddingEnd="16dp"
        android:background="@color/grid_background" android:inputType="text" />
    <ListView android:id="@+id/lvOpciones" android:layout_width="match_parent"
        android:layout_height="300dp" android:dividerHeight="1dp" android:divider="@color/divider" />
</LinearLayout>