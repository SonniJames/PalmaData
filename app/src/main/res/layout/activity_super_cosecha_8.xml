<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/grid_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal" android:background="@color/header_background" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="6dp">
        <ImageView android:layout_width="52dp" android:layout_height="52dp" android:src="@drawable/logo_palma" android:scaleType="fitCenter" android:contentDescription="Logo" />
        <View android:layout_width="12dp" android:layout_height="match_parent" />
        <ImageView android:layout_width="0dp" android:layout_height="26dp" android:layout_weight="1" android:src="@drawable/texto_palma_data" android:scaleType="fitStart" android:adjustViewBounds="true" android:contentDescription="PalmaData" />
    </LinearLayout>
    <TextView android:layout_width="match_parent" android:layout_height="48dp" android:text="OBSERVACIONES"
        android:gravity="center" android:textSize="16sp" android:textColor="@color/text_secondary"
        android:background="@color/white" android:elevation="2dp" />
    <EditText android:id="@+id/etObservaciones" android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_margin="16dp" android:padding="12dp"
        android:background="@color/white" android:gravity="top|start"
        android:hint="Ingrese observaciones (máx. 250 caracteres)" android:textSize="15sp"
        android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary"
        android:inputType="textMultiLine|textCapSentences" android:maxLength="250" />
    <TextView android:id="@+id/tvContador" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="end" android:paddingEnd="16dp" android:paddingBottom="4dp"
        android:text="0/250" android:textSize="12sp" android:textColor="@color/text_secondary" />
    <Button android:id="@+id/btnGuardar" android:layout_width="match_parent" android:layout_height="60dp"
        android:layout_margin="16dp" android:text="GUARDAR" android:textSize="16sp" android:textStyle="bold"
        android:backgroundTint="@color/palma_green_dark" android:textColor="@color/white" />
</LinearLayout>